{
  "name": "mempalace",
  "version": "0.1.0",
  "description": "MemPalace — native macOS desktop wrapper for the Claude agent loop",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "build:vite": "vite build",
    "preview": "vite preview",
    "dist:mac": "npm run build:vite && electron-builder --mac --arm64 --dir",
    "dist:mac:dmg": "npm run build:vite && electron-builder --mac --arm64",
    "install:app": "rm -rf '/Applications/MemPalace.app' && cp -R 'dist-builder/mac-arm64/MemPalace.app' '/Applications/MemPalace.app'"
  },
  "build": {
    "appId": "app.mempalace.desktop",
    "productName": "MemPalace",
    "directories": {
      "output": "dist-builder",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!**/{.DS_Store,.git,.gitignore,.eslintrc.cjs,.prettierrc,.editorconfig}"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/**/*",
      "node_modules/@anthropic-ai/claude-agent-sdk/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dir",
          "arch": "arm64"
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "extendInfo": {
        "NSCameraUsageDescription": "MemPalace doesn't use the camera.",
        "NSMicrophoneUsageDescription": "MemPalace doesn't use the microphone."
      }
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.121",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.12.0",
    "imapflow": "^1.3.2",
    "mailparser": "^3.9.8",
    "nodemailer": "^8.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  }
}
